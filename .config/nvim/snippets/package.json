{
  "name": "friendly-snippets",
  "engines": {
    "vscode": "^1.11.0"
  },
  "contributes": {
    "snippets": [
      {
        "language": "lua",
        "path": "./lua.json"
      },
      {
        "language": [
          "markdown",
          "rmd"
        ],
        "path": "./markdown.json"
      },
      {
        "language": [
          "html",
          "jade",
          "pug",
          "javascriptreact",
          "typescriptreact",
          "blade"
        ],
        "path": "./html.json"
      },
      {
        "language": [
          "css",
          "scss",
          "sass",
          "less",
          "stylus"
        ],
        "path": "./css.json"
      },
      {
        "language": [
          "javascript",
          "typescript",
          "javascriptreact",
          "typescriptreact",
          "vue",
          "svelte"
        ],
        "path": "./javascript/javascript.json"
      },
      {
        "language": "jsdoc",
        "path": "./javascript/jsdoc.json"
      },
      {
        "language": "tsdoc",
        "path": "./javascript/tsdoc.json"
      },
      {
        "language": [
          "typescript",
          "typescriptreact"
        ],
        "path": "./javascript/typescript.json"
      },
      {
        "language": [
          "typescriptreact",
          "javascriptreact"
        ],
        "path": "./javascript/react-es7.json"
      },
      {
        "language": "javascriptreact",
        "path": "./javascript/next.json"
      },
      {
        "language": "typescriptreact",
        "path": "./javascript/next-ts.json"
      }
    ]
  }
}
